{
	"name": "frontend",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "rsbuild build",
		"build:git": "node git-pull.js && rsbuild build && node build-for-git.js",
		"build:deploy": "rsbuild build && node deploy.js",
		"dev": "rsbuild dev",
		"operation": "rsbuild dev RSBUILD_MODE=operation --open --mode=development",
		"preview": "rsbuild preview",
		"format": "prettier --write .",
		"lint": "eslint . --ext .vue,.ts,.tsx",
		"lint:fix": "eslint . --ext .vue,.ts,.tsx --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
